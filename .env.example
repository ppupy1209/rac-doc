# 이 파일을 `.env`로 복사해 값을 바꾼 뒤 `docker compose up` 하세요.
# .env는 gitignore라 커밋되지 않습니다.

# ─────────────────────────────────────────────────────────────
# 1) 답변 품질 (권장: Gemini 키 1개)
# ─────────────────────────────────────────────────────────────
# 챗 LLM 프로바이더: ollama | gemini   (임베딩은 어느 쪽이든 Ollama nomic-embed-text 고정)
#
#   ollama  — 키 불필요. 단, 이 프로젝트의 골든셋 실측으로 llama3.2:3b는
#             환각률 75% · 질문분류 41.7%(전부 WIKI로 찍는 축퇴) · 재작성은 환각·언어 혼입.
#   gemini  — 무료 키 하나로 환각률 0% · 분류 97.2% · 지연 0.6s(vs 8.8s). 카드 등록 불필요.
#
# 키 발급: https://aistudio.google.com/apikey (Google AI Studio, 무료 티어)
# 모델은 gemini-3.1-flash-lite 고정 — 무료 티어에서 RPM 15·RPD 500으로 유일하게 평가 완주 가능
# (2.5-flash·3.5-flash는 RPD 20이라 불가. design-notes §4 참고).
ASKWIKI_LLM_PROVIDER=ollama
GOOGLE_GENAI_API_KEY=

# ─────────────────────────────────────────────────────────────
# 2) 기능 스위치
# ─────────────────────────────────────────────────────────────
# 벡터 인덱스: memory(인메모리 브루트포스) | elasticsearch(ES kNN — 컨테이너는 이미 뜬다)
# 20k 청크 실측: 인메모리 22.8ms vs ES 12.8ms (design-notes §5)
VECTOR_INDEX_IMPL=memory

# 하이브리드 검색(B5): BM25(어휘) + kNN(의미)을 자체 RRF로 융합.
# ⚠️ VECTOR_INDEX_IMPL=elasticsearch일 때만 동작한다(memory 인덱스는 어휘 검색 불가).
# 실측(30문항): hit rate@1 36.7% → 90.0%, @2 56.7% → 93.3%, @4 90.0% → 100% (design-notes §8).
# 켜면 기동 시 1회 재색인이 돈다(옛 인덱스엔 본문이 없어서). 어휘가 안 맞는 질문에선 벡터 단독과 동일 = 손해 없음.
ASKWIKI_SEARCH_HYBRID=false

# 질문 분류·라우팅(C3-2): 위키검색 / 즉답 / 되묻기로 분기.
# ⚠️ ollama에선 켜지 마세요 — 전부 WIKI로 찍는 축퇴라 이득 0에 토큰만 낭비(실측).
ASKWIKI_ROUTING_ENABLED=false

# ─────────────────────────────────────────────────────────────
# 3) 호스트 포트 오버라이드 (컨테이너 내부 포트는 그대로)
# ─────────────────────────────────────────────────────────────
# 로컬에 이미 MySQL(3306)이나 Grafana(3000) 등이 떠 있어 충돌할 때만 바꾸세요.
APP_PORT=8080
MYSQL_PORT=3306
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
REDIS_HOST_PORT=6379
